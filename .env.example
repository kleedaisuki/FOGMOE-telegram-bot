# =============================================================================
# AI 路由配置（LiteLLM）
# =============================================================================
# 主聊天 provider fallback 顺序，按从左到右依次尝试。
# 可选值：openai, openrouter, siliconflow, gemini, zhipu, zai, azure
AI_CHAT_ORDER=gemini,zhipu,siliconflow

# 命中这些逗号分隔的 shell-style 模式时，聊天模型不会直接接收图片输入。
# 这类模型会改用已由 vision 任务生成图片描述的纯文本聊天历史。
AI_CHAT_TEXT_ONLY_MODELS=deepseek-ai/DeepSeek-V4-Flash

# 各类后台任务使用的 provider。
# fallback provider 可选；不需要时保持注释即可。
AI_SUMMARY_PROVIDER=gemini
# AI_SUMMARY_FALLBACK_PROVIDER=azure

AI_TRANSLATE_PROVIDER=zhipu
# AI_TRANSLATE_FALLBACK_PROVIDER=openai

# 聊天历史 token 阈值（可选）。provider-neutral 启发式计数先乘以
# 1.15 guard ratio，再与 warning/hard 阈值比较，为工具 schema 与模型差异保留余量。
# CHAT_TOKEN_WARN_LIMIT=114000
# CHAT_TOKEN_LIMIT=120000
# 输出 token、tool schema 与 provider framing 的统一预留。
# CHAT_RESERVED_TOKENS=8192


# =============================================================================
# OpenAI 配置（LiteLLM provider: openai/<model>）
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# 可选：OpenAI-compatible endpoint；使用官方 OpenAI 时通常不需要设置。
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_CHAT_MODEL=gpt-4o
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_TRANSLATE_MODEL=gpt-4o-mini


# =============================================================================
# OpenRouter 配置（LiteLLM provider: openrouter/<model>）
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 可选：默认使用 https://openrouter.ai/api/v1。
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_SUMMARY_MODEL=openai/gpt-4o-mini
OPENROUTER_TRANSLATE_MODEL=openai/gpt-4o-mini


# =============================================================================
# SiliconFlow 配置（OpenAI-compatible endpoint）
# =============================================================================
# Chat Completions 完整接口：
# https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

SILICONFLOW_CHAT_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_SUMMARY_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_TRANSLATE_MODEL=deepseek-ai/DeepSeek-V4-Flash


# =============================================================================
# Google Gemini 配置（LiteLLM provider: gemini/<model>）
# =============================================================================
# API Key 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 默认留空，使用 Google AI Studio 原生 Gemini endpoint。
GEMINI_API_BASE=

# 仅当 GEMINI_API_BASE 指向 OpenAI-compatible Gemini 代理时设为 true。
GEMINI_OPENAI_COMPATIBLE=false

GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_CHAT_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_SUMMARY_FALLBACK_MODEL=gemini-2.5-flash-lite


# =============================================================================
# Azure OpenAI 配置（LiteLLM provider: azure/<deployment>）
# =============================================================================
# 获取地址：https://portal.azure.com/
AZURE_OPENAI_API_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=your_azure_deployment_name

AZURE_OPENAI_CHAT_MODEL=your_azure_deployment_name
# AZURE_OPENAI_SUMMARY_MODEL=your_azure_deployment_name
# AZURE_OPENAI_TRANSLATE_MODEL=your_azure_deployment_name


# =============================================================================
# Z.ai / 智谱配置（LiteLLM provider: zai/<model>）
# =============================================================================
# API Key 获取地址：https://open.bigmodel.cn/
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_BASE=https://open.bigmodel.cn/api/paas/v4

ZHIPU_CHAT_MODEL=glm-4.7-flash
ZHIPU_TRANSLATE_MODEL=glm-4.7-flash
# ZHIPU_SUMMARY_MODEL=glm-4.5-flash


# =============================================================================
# Telegram Bot 配置
# =============================================================================
# Token 获取地址：https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Listener 只负责 durable ingestion；业务并发由下面的 keyed mailbox runtime 管理。
RUNTIME_MAX_CONCURRENCY=32
RUNTIME_GLOBAL_CAPACITY=512
RUNTIME_PER_KEY_CAPACITY=8
RUNTIME_MAILBOX_IDLE_TTL_SECONDS=300
RUNTIME_SHUTDOWN_GRACE_SECONDS=30

# 所有后台 worker 与 Telegram listener 共用一个主 event loop；容量限制的是已领取未终结工作。
SCHEDULING_POLL_INTERVAL=1.0
SCHEDULING_WORKER_COUNT=3
# 进程崩溃后，超过此租约的 executing 任务会被下一次启动回收。
SCHEDULING_LEASE_SECONDS=1800

INBOX_WORKER_COUNT=16
INBOX_POLL_INTERVAL=0.1
INBOX_LEASE_SECONDS=60

INFERENCE_WORKER_COUNT=8
INFERENCE_POLL_INTERVAL=0.25
INFERENCE_PROVIDER_TIMEOUT_SECONDS=90
INFERENCE_LEASE_SECONDS=180
INFERENCE_ATTEMPT_TIMEOUT_SECONDS=120

# 摘要走独立固定 consumer 池；单 route timeout < 整次 fallback budget < lease。
COMPACTION_WORKER_COUNT=2
COMPACTION_POLL_INTERVAL=0.5
COMPACTION_PROVIDER_TIMEOUT_SECONDS=30
COMPACTION_ATTEMPT_TIMEOUT_SECONDS=120
COMPACTION_LEASE_SECONDS=180

OUTBOX_WORKER_COUNT=16
OUTBOX_POLL_INTERVAL=0.1
OUTBOX_LEASE_SECONDS=60
OUTBOX_ATTEMPT_TIMEOUT_SECONDS=25

# =============================================================================
# 统一出站代理配置 / Unified outbound proxy configuration
# =============================================================================
# 所有互联网 HTTP 请求（Telegram、AI、搜索、图片、音频等）都使用此代理。
# 支持 http://、https://、socks5:// 和 socks5h://；留空则直连。
# 例：NETWORK_PROXY_URL=socks5://host.docker.internal:7891
NETWORK_PROXY_URL=


# =============================================================================
# 日志配置 / Logging configuration
# =============================================================================
LOG_LEVEL=INFO
# 每次启动创建 tgbot_YYYYMMDDTHHMMSS+ZZZZ_PID.log。
LOG_FILE_MAX_BYTES=1048576
LOG_FILE_BACKUP_COUNT=5
LOG_QUEUE_MAX_SIZE=10000
# LiteLLM 通过项目统一日志管道输出；推荐 WARNING，排障时可设为 INFO 或 DEBUG。
LITELLM_LOG_LEVEL=WARNING


# =============================================================================
# PostgreSQL 数据库配置
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=fogmoe

# 运行时 schema 搜索路径；迁移 SQL 会显式创建这些 schema。
DB_SEARCH_PATH=identity,conversation,assistant,economy,moderation,crypto,game,media,admin,public
DB_MIGRATION_SCHEMA=infra


# =============================================================================
# 搜索 API 配置
# =============================================================================
# SerpApi Key 获取地址：https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here


# =============================================================================
# 代码执行 API 配置
# =============================================================================
# Judge0 API Key 获取地址：https://ce.judge0.com/
JUDGE0_API_KEY=your_judge0_api_key_here

# =============================================================================
# 图片生成 API 配置
# =============================================================================
IMAGE_GEN_API_URL=
IMAGE_GEN_API_TOKEN=your_image_generation_api_token_here


# =============================================================================
# Fish Audio 语音生成配置
# =============================================================================
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here
FISH_AUDIO_MODEL=s2.1-pro-free
FISH_AUDIO_REFERENCE_ID=dc020cb237df4248907565718715b20b
